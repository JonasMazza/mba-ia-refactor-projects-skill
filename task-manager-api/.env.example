# Copy to `.env` for local development. Never commit `.env`.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
PORT=5557

# Database
DB_URL=sqlite:///tasks.db

# Auth
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24
# Set to true ONLY in dev/CI to bypass @requires_auth checks.
AUTH_DISABLED=true

# CORS — comma-separated allowlist
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP (NotificationService)
NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
