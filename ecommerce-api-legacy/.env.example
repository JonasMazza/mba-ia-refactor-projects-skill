# Server
PORT=3000

# Database (better-sqlite3). Use ":memory:" for ephemeral dev DB.
DB_PATH=:memory:

# Auth
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_EXPIRES_IN=1h
# Dev escape hatch — when "true", auth middleware is bypassed (only for local dev / validation curls).
AUTH_DISABLED=false

# Payment gateway (do NOT commit real keys)
PAYMENT_GATEWAY_KEY=pk_test_replace_me

# Logger
LOG_LEVEL=info
